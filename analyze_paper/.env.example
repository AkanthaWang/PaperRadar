# vivo AI 开放平台 AppID，用于参与接口鉴权签名。
PAPER_ANALYZER_APP_ID=2026945506

# vivo AI 开放平台 AppKEY，用于生成签名。敏感信息，不要提交到 Git。
PAPER_ANALYZER_APP_KEY=sk-xuanji-2026945506-Q0piQmJFUFZwUVZmSFlrTQ==

# 认证模式：hmac（默认签名）或 bearer（按你提供的示例）。
PAPER_ANALYZER_AUTH_MODE=hmac

# 使用的 vivo 蓝心大模型名称。
PAPER_ANALYZER_MODEL=qwen3.5-plus

# vivo API 域名，默认使用官方 AI 网关。
PAPER_ANALYZER_DOMAIN=https://api-ai.vivo.com.cn/v1

# LLM 聊天补全接口路径。
PAPER_ANALYZER_URI=/chat/completions

# 每篇论文最多抽取并插入 Markdown 的原图数量。
PAPER_ANALYZER_MAX_IMAGES=8

# 单次最终总结 prompt 最多发送的论文文本字符数，超长论文会走分段总结。
PAPER_ANALYZER_MAX_CHARS=60000

# API 请求超时时间，单位是秒。
PAPER_ANALYZER_TIMEOUT=120

# 模型采样温度。越低越稳定，越高越发散；论文总结建议 0.1-0.3。
PAPER_ANALYZER_TEMPERATURE=0.2
